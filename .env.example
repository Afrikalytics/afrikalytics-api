# Database (Railway fournira automatiquement DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/afrikalytics

# Secret pour les tokens JWT
SECRET_KEY=your-super-secret-key-change-in-production

# Secret pour Zapier (à définir dans Zapier aussi)
ZAPIER_SECRET=your-zapier-secret-key

# Environnement
ENVIRONMENT=development

# Port (Railway définit automatiquement PORT)
PORT=8000
