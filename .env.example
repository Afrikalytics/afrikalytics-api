# Database (Railway fournira automatiquement DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/afrikalytics

# Secret pour les tokens JWT (OBLIGATOIRE en production — utilisez une valeur longue et aleatoire)
SECRET_KEY=your-secret-key-here-change-in-production

# API Resend pour l'envoi d'emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# PayDunya — paiements FCFA / mobile money
PAYDUNYA_MASTER_KEY=your-key
PAYDUNYA_PRIVATE_KEY=your-key
PAYDUNYA_PUBLIC_KEY=your-key
PAYDUNYA_TOKEN=your-token
PAYDUNYA_MODE=test

# Secret pour Zapier (a definir dans Zapier aussi)
ZAPIER_SECRET=your-zapier-secret-key

# Secret pour le cron job de verification des abonnements
CRON_SECRET=your-cron-secret-key

# Sentry — monitoring d'erreurs (obtenir le DSN depuis sentry.io)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Redis (cache pour les endpoints publics)
REDIS_URL=redis://localhost:6379/0

# Environnement (development | production)
ENVIRONMENT=development

# URL du frontend (pour CORS et liens dans les emails)
FRONTEND_URL=https://afrikalytics.vercel.app

# Port (Railway definit automatiquement PORT)
PORT=8000
